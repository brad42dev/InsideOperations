# Inside/Operations — Environment Configuration
# Copy to .env and fill in values before starting services.
# Lines beginning with # are comments.

# =============================================================================
# 1. Database
# =============================================================================

# PostgreSQL connection URL (required by all services that touch the DB).
IO_DATABASE_URL=postgresql://io:io_password@localhost:5432/io_dev

# Maximum simultaneous DB connections per service pool (default: 20).
# With 11 services each using this limit, ensure PostgreSQL max_connections
# is set high enough (e.g. 300). Lower this (e.g. 10) on constrained hosts.
IO_DB_MAX_CONNECTIONS=20

# =============================================================================
# 2. Security (JWT, service secret, CORS)
# =============================================================================

# HS256 signing secret for access tokens.
# Generate: openssl rand -hex 32
IO_JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# Shared secret for service-to-service calls (x-io-service-secret header).
# Generate: openssl rand -hex 32
IO_SERVICE_SECRET=changeme_generate_with_openssl_rand_hex_32

# Comma-separated list of origins the API Gateway will accept CORS requests from.
# Leave empty (or unset) to allow all origins — development only.
# Production example: https://app.example.com,https://ops.example.com
CORS_ALLOWED_ORIGINS=

# =============================================================================
# 3. Auth providers
# =============================================================================

# --- SAML SP (Service Provider) ---
# Entity ID advertised in the SP metadata XML.
SAML_SP_ENTITY_ID=https://io.example.com/saml/metadata

# Assertion Consumer Service URL where the IdP posts the SAML response.
SAML_ACS_URL=https://io.example.com/api/auth/saml/acs

# --- OIDC (placeholder — configure in the auth_providers DB table) ---
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_DISCOVERY_URL=

# =============================================================================
# 4. Service ports
# =============================================================================

# Each service binds to 0.0.0.0:<PORT>. Override if the default conflicts.
API_GATEWAY_PORT=3000
DATA_BROKER_PORT=3001
OPC_SERVICE_PORT=3002
EVENT_SERVICE_PORT=3003
PARSER_SERVICE_PORT=3004
ARCHIVE_SERVICE_PORT=3005
IMPORT_SERVICE_PORT=3006
ALERT_SERVICE_PORT=3007
EMAIL_SERVICE_PORT=3008
AUTH_SERVICE_PORT=3009
RECOGNITION_SERVICE_PORT=3010

# =============================================================================
# 5. Inter-service URLs
# =============================================================================

# The API Gateway proxies to these addresses. In production they are all
# localhost (127.0.0.1) because every service runs on the same host.
AUTH_SERVICE_URL=http://127.0.0.1:3009
EVENT_SERVICE_URL=http://127.0.0.1:3003
EMAIL_SERVICE_URL=http://127.0.0.1:3008
IMPORT_SERVICE_URL=http://127.0.0.1:3006
RECOGNITION_SERVICE_URL=http://127.0.0.1:3010
ALERT_SERVICE_URL=http://127.0.0.1:3007
PARSER_SERVICE_URL=http://127.0.0.1:3004
ARCHIVE_SERVICE_URL=http://127.0.0.1:3005
DATA_BROKER_URL=http://127.0.0.1:3001

# =============================================================================
# 6. Session & rate limiting
# =============================================================================

# Maximum concurrent sessions a single user may hold (IEC 62443 SR 2.7).
MAX_SESSIONS_PER_USER=3

# Refresh token lifetime in seconds (default: 7 days = 604800).
REFRESH_TOKEN_TTL_SECS=604800

# Lock an account after this many consecutive failed login attempts.
MAX_FAILED_LOGINS=5

# How long (seconds) to keep an account locked after MAX_FAILED_LOGINS.
LOCKOUT_DURATION_SECS=300

# =============================================================================
# 7. Data Broker / WebSocket
# =============================================================================

# Unix domain socket used by the OPC Service to push point updates to the
# Data Broker. Must match OPC_BROKER_SOCK in the OPC service.
OPC_BROKER_SOCK=/var/run/io/opc-broker.sock

# Maximum number of point subscriptions a single WebSocket client may hold.
MAX_SUBSCRIPTIONS_PER_CLIENT=5000

# Seconds between WebSocket ping frames sent to clients.
PING_INTERVAL_SECS=30

# How often (seconds) the Data Broker sweeps for stale point values.
STALENESS_SWEEP_SECS=10

# A point is considered stale if it has not been updated within this window.
STALE_THRESHOLD_SECS=60

# =============================================================================
# 8. OPC UA
# =============================================================================

# How often (milliseconds) the OPC Service flushes accumulated updates to the
# Data Broker UDS socket.
BATCH_INTERVAL_MS=250

# Maximum number of point updates included in a single flush batch.
BATCH_MAX_POINTS=500

# Number of monitored items created per OPC subscription call.
SUBSCRIPTION_BATCH_SIZE=500

# OPC UA publishing interval in milliseconds (how often the server sends data).
PUBLISHING_INTERVAL_MS=1000

# Maximum backoff (seconds) between OPC UA reconnect attempts.
RECONNECT_MAX_SECS=60

# =============================================================================
# 9. Archive & time-series
# =============================================================================

# Raw (per-second) point values are retained for this many days.
RETENTION_RAW_DAYS=90

# 1-minute aggregate retention in days.
RETENTION_1M_DAYS=365

# 5-minute aggregate retention in days (default ~2 years).
RETENTION_5M_DAYS=730

# 1-hour aggregate retention in days (default ~5 years).
RETENTION_1H_DAYS=1825

# Compress TimescaleDB chunks older than this many days.
COMPRESSION_AFTER_DAYS=7

# How often (seconds) the Archive Service runs its maintenance job
# (compression + retention enforcement).
MAINTENANCE_INTERVAL_SECS=3600

# =============================================================================
# 10. Recognition service
# =============================================================================

# Directory where .iomodel packages are stored for P&ID/DCS symbol recognition.
IO_MODEL_DIR=/opt/io/models

# =============================================================================
# 11. Export
# =============================================================================

# Directory where generated report files (CSV, XLSX, HTML, PDF) are written.
# Dev default: /tmp/io-exports   Production: /opt/io/exports
IO_EXPORT_DIR=/tmp/io-exports

# =============================================================================
# 12. Observability
# =============================================================================

# Structured log level for all services (trace|debug|info|warn|error).
IO_LOG_LEVEL=info

# Set to true to enable OpenTelemetry distributed tracing export.
IO_TRACING_ENABLED=false

# OTLP gRPC endpoint for tracing (Jaeger, Grafana Tempo, etc.).
IO_OTLP_ENDPOINT=http://localhost:4317

# Prometheus scrape interval hint in seconds.
IO_METRICS_INTERVAL=15

# Prometheus collection timeout in seconds.
IO_METRICS_TIMEOUT=5

# Enable the built-in Prometheus metrics collector.
IO_METRICS_COLLECTOR_ENABLED=true

# =============================================================================
# 13. Mobile API / PWA config (Rounds mobile client)
# =============================================================================

# Public URL of this IO instance, used in SAML ACS URLs and mobile deep links.
FRONTEND_URL=https://io.example.com

# How often the mobile client polls for new round assignments (milliseconds).
MOBILE_SYNC_INTERVAL_MS=30000

# How often the mobile client sends a presence heartbeat (milliseconds).
MOBILE_HEARTBEAT_INTERVAL_MS=60000

# How long offline data is cached in IndexedDB before expiring (minutes).
MOBILE_OFFLINE_CACHE_DURATION_MINS=480

# Require GPS coordinates for round checkpoint submissions.
MOBILE_GPS_REQUIRED=false

# Minimum touch target size enforced by the mobile client (pixels).
MOBILE_MIN_TOUCH_TARGET_PX=44

# Recognition service port (defaults to 3010 if unset).
RECOGNITION_PORT=3010

# =============================================================================
# 14. TimescaleDB retention policy overrides
# =============================================================================

# How many days to retain 1-minute aggregates (default: 90).
RETENTION_1M_DAYS=90

# How many days to retain 5-minute aggregates (default: 365).
RETENTION_5M_DAYS=365

# How many days to retain 1-hour aggregates (default: 1825 = 5 years).
RETENTION_1H_DAYS=1825

# =============================================================================
# 15. Frontend dev server
# =============================================================================

# Base URL the Vite dev proxy forwards /api/* requests to.
VITE_API_URL=http://localhost:3000

# WebSocket URL for the Data Broker (used by the WS connection manager).
VITE_WS_URL=ws://localhost:3001

# Set to true to enable the service worker in development builds.
# Disabled by default to avoid stale-cache issues during development.
VITE_ENABLE_SW=false
