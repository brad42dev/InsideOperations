{
  "schema": "io-orchestrator/v1",

  "project": {
    "name": "io",
    "root": "."
  },

  "commands": {
    "build_backend":  "cargo build",
    "test_backend":   "cargo test",
    "lint_backend":   "cargo clippy -- -D warnings",
    "check_backend":  "cargo check",
    "build_frontend": "cd frontend && pnpm build",
    "test_frontend":  "cd frontend && pnpm test",
    "lint_frontend":  "cd frontend && pnpm lint",
    "check_frontend": "cd frontend && npx tsc --noEmit",
    "backend_start":  "./dev.sh start",
    "backend_stop":   "./dev.sh stop",
    "backend_health": "curl -sf --max-time 2 --connect-timeout 1 http://localhost:3000/health/live",
    "frontend_dev":   "cd frontend && pnpm dev",
    "frontend_health":"curl -s --max-time 5 http://localhost:5173",
    "integration_test": "cd frontend && npx tsx tests/integration/runner.ts"
  },

  "ports": {
    "backend":  3000,
    "frontend": 5173
  },

  "paths": {
    "task_dir":        "docs/tasks",
    "state_dir":       "docs/state",
    "catalog_dir":     "docs/catalogs",
    "decisions_dir":   "docs/decisions",
    "uat_dir":         "docs/uat",
    "spec_manifest":   "docs/SPEC_MANIFEST.md",
    "spec_docs":       "/home/io/spec_docs",
    "design_docs":     "design-docs",
    "comms_dir":       "comms",
    "registry_file_backup": "comms/AUDIT_PROGRESS.json",
    "needs_input_dir": "comms/needs_input",
    "escalated_dir":   "comms/escalated",
    "last_round_file": "comms/LAST_ROUND.json",
    "ledger_dir":      "docs/state/ledger",
    "registry_db":     "comms/tasks.db",
    "worktree_base":   "/tmp/io-worktrees"
  },

  "task_store": {
    "type": "sqlite",
    "path": "comms/tasks.db",
    "wal_mode": true
  },

  "agents": {
    "max_parallel":             4,
    "max_audit_parallel":       2,
    "model_orchestrator":       "claude-opus-4-6",
    "model_worker":             "claude-sonnet-4-6",
    "heartbeat_interval_sec":   30,
    "stale_task_threshold_min": 30,
    "stale_uat_threshold_min":  15,
    "checkpoint_every":         3,
    "max_repair_attempts":      3,
    "max_impl_attempts":        3,
    "needs_input_stale_hours":  48,
    "needs_input_escalate_hours": 144,
    "rate_limit_backoff_sec":   60,
    "max_zero_waves":           3
  },

  "never_touch": [
    ".env",
    ".env.*",
    "*.lock",
    ".git/",
    "node_modules/",
    "comms/context/",
    "migrations/",
    "secrets/",
    "/home/io/spec_docs/"
  ],

  "units": [
    { "id": "CX-EXPORT",         "name": "Universal Export",                    "wave": 0, "source_paths": ["frontend/src/components/export/"], "spec_doc": null },
    { "id": "CX-POINT-CONTEXT",  "name": "Point Right-Click Context Menu",      "wave": 0, "source_paths": ["frontend/src/components/PointContextMenu.tsx"], "spec_doc": "/home/io/spec_docs/context-menu-implementation-spec.md" },
    { "id": "CX-ENTITY-CONTEXT", "name": "Entity List Right-Click Context Menu","wave": 0, "source_paths": ["frontend/src/components/EntityContextMenu.tsx"], "spec_doc": "/home/io/spec_docs/context-menu-implementation-spec.md" },
    { "id": "CX-CANVAS-CONTEXT", "name": "Designer Canvas Right-Click Menus",  "wave": 0, "source_paths": ["frontend/src/pages/designer/"], "spec_doc": "/home/io/spec_docs/context-menu-implementation-spec.md" },
    { "id": "CX-POINT-DETAIL",   "name": "Point Detail Floating Panel",         "wave": 0, "source_paths": ["frontend/src/components/PointDetailPanel.tsx"], "spec_doc": null },
    { "id": "CX-PLAYBACK",       "name": "Historical Playback Bar",             "wave": 0, "source_paths": ["frontend/src/components/PlaybackBar.tsx"], "spec_doc": null },
    { "id": "CX-RBAC",           "name": "Per-Module RBAC Enforcement",         "wave": 0, "source_paths": ["frontend/src/hooks/usePermission.ts"], "spec_doc": null },
    { "id": "CX-ERROR",          "name": "React Error Boundary",                "wave": 0, "source_paths": ["frontend/src/components/ErrorBoundary.tsx"], "spec_doc": null },
    { "id": "CX-LOADING",        "name": "Module Skeleton Loading States",      "wave": 0, "source_paths": ["frontend/src/components/skeletons/"], "spec_doc": null },
    { "id": "CX-EMPTY",          "name": "Tailored Empty States",               "wave": 0, "source_paths": ["frontend/src/components/EmptyState.tsx"], "spec_doc": null },
    { "id": "CX-TOKENS",         "name": "Design Token Compliance",             "wave": 0, "source_paths": ["frontend/src/styles/", "frontend/tailwind.config.ts"], "spec_doc": null },
