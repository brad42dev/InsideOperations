{
  "id": "tank-storage-floating-roof",
  "category": "tanks",
  "geometry": { "viewBox": "0 0 70 70", "width": 70, "height": 70 },
  "connections": [
    { "id": "inlet",  "type": "process", "x": 10, "y": 40, "direction": "left" },
    { "id": "outlet", "type": "process", "x": 60, "y": 40, "direction": "right" }
  ],
  "textZones": [
    { "id": "tagname", "x": 35, "y": -6, "width": 70, "anchor": "middle", "fontSize": 11 }
  ],
  "valueAnchors": [
    { "nx": 0.5, "ny": 1.1, "preferredElement": "text_readout" },
    { "nx": 0.5, "ny": 0.6, "preferredElement": "fill_gauge" }
  ],
  "alarmAnchor": { "nx": 1.1, "ny": -0.05 },
  "states": {
    "running": "io-running",
    "stopped": "io-stopped",
    "fault": "io-fault",
    "transitioning": "io-transitioning",
    "oos": "io-oos"
  }
}
