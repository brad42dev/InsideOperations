      "opt1": {
        "file": "valve-gate.svg",
        "label": "ISA Standard"
      }
    },
    "configurations": []
  },
  "alarmBinding": {
    "stateSource": "point_alarm_state",
    "priorityMapping": {
      "1": "al-urgent",
      "2": "al-high",
      "3": "al-low",
      "4": "al-diagnostic"
    },
    "unacknowledgedFlash": true,
    "flashRate": "1Hz"
  },
  "geometry": {
    "viewBox": "0 0 48 24",
    "width": 48,
    "height": 24
  },
  "connections": [
    {
      "id": "inlet",
      "type": "process",
      "x": 0,
      "y": 12,
      "direction": "left"
    },
    {
      "id": "outlet",
      "type": "process",
      "x": 48,
      "y": 12,
      "direction": "right"
    }
  ],
  "textZones": [
    {
      "id": "tagname",
      "x": 24,
      "y": -6,
      "width": 48,
      "anchor": "middle",
      "fontSize": 11
    }
  ],
  "valueAnchors": [
    {
      "nx": 0.5,
      "ny": 1.4,
      "preferredElement": "text_readout"
    }
  ],
  "alarmAnchor": {
    "nx": 1.1,
    "ny": -0.2
  },
  "states": {
    "running": "io-running",
    "stopped": "io-stopped",
    "fault": "io-fault",
    "transitioning": "io-transitioning",
    "oos": "io-oos"
  },
  "addons": [
    {
      "id": "actuator-diaphragm",
      "file": "part-actuator-diaphragm.svg",
      "label": "Pneumatic (Diaphragm)",
      "group": "actuator",
      "exclusive": true
    },
    {
      "id": "actuator-motor",
      "file": "part-actuator-motor.svg",
      "label": "Motorized (Electric)",
      "group": "actuator",
      "exclusive": true
    },
    {
      "id": "actuator-solenoid",
      "file": "part-actuator-solenoid.svg",
      "label": "Solenoid",
      "group": "actuator",
      "exclusive": true
    },
    {
      "id": "fail-open",
      "file": "part-fail-open.svg",
      "label": "Fail Open (FO)",
      "group": "fail-indicator",
      "exclusive": true
    },
    {
      "id": "fail-closed",
      "file": "part-fail-closed.svg",
      "label": "Fail Closed (FC)",
      "group": "fail-indicator",
      "exclusive": true
    },
    {
      "id": "fail-last",
      "file": "part-fail-last.svg",
      "label": "Fail Last (FL)",
      "group": "fail-indicator",
      "exclusive": true
    }
