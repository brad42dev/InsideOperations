{
  "$schema": "io-shape-v1",
  "shape_id": "valve-gate",
  "version": "1.0",
  "display_name": "Gate Valve",
  "category": "valves",
  "subcategory": "gate",
  "tags": [
    "valve",
    "gate",
    "isolation"
  ],
  "recognition_class": "valve_gate",
  "variants": {
