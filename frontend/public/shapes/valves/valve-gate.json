    },
    {
      "partId": "actuator-diaphragm",
      "label": "Pneumatic Actuator",
      "category": "actuator"
    },
    {
      "partId": "actuator-motor",
      "label": "Motorized Actuator",
      "category": "actuator"
    },
    {
      "partId": "actuator-solenoid",
      "label": "Solenoid Actuator",
      "category": "actuator"
    }
  ]
