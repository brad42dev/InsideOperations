{
  "$schema": "io-shape-v1",
  "shape_id": "valve-control",
  "version": "1.0",
  "display_name": "Control Valve",
  "category": "valves",
  "subcategory": "control",
  "tags": [
    "valve",
    "control",
    "modulating",
    "throttling"
  ],
  "recognition_class": "valve_control",
  "variants": {
    "options": {
      "opt1": {
        "file": "valve-control.svg",
        "label": "ISA Standard"
      }
    },
    "configurations": []
  },
  "alarmBinding": {
    "stateSource": "point_alarm_state",
    "priorityMapping": {
      "1": "al-urgent",
      "2": "al-high",
      "3": "al-low",
      "4": "al-diagnostic"
    },
    "unacknowledgedFlash": true,
    "flashRate": "1Hz"
  },
  "geometry": {
    "viewBox": "0 0 48 44",
    "width": 48,
    "height": 44
  },
  "connections": [
    {
      "id": "inlet",
      "type": "process",
      "x": 0,
      "y": 32,
      "direction": "left"
    },
    {
      "id": "outlet",
      "type": "process",
      "x": 48,
      "y": 32,
      "direction": "right"
    },
    {
      "id": "actuator",
      "type": "signal",
      "x": 24,
      "y": 0,
      "direction": "top"
    }
  ],
  "textZones": [
    {
      "id": "tagname",
      "x": 24,
      "y": -6,
      "width": 48,
      "anchor": "middle",
      "fontSize": 11
    }
  ],
  "valueAnchors": [
    {
      "nx": 0.5,
      "ny": 1.15,
      "preferredElement": "text_readout"
    },
    {
      "nx": 0.5,
      "ny": 1.3,
      "preferredElement": "sparkline"
    }
  ],
  "alarmAnchor": {
    "nx": 1.1,
    "ny": -0.1
  },
  "states": {
    "running": "io-running",
    "stopped": "io-stopped",
    "fault": "io-fault",
    "transitioning": "io-transitioning",
    "oos": "io-oos"
  },
  "compositeAttachments": [
    { "forPart": "fail-open",        "x": 36.5, "y": -8.5 },
    { "forPart": "fail-open-left",   "x": 11.5, "y": -8.5 },
    { "forPart": "fail-closed",      "x": 36.5, "y": -8.5 },
    { "forPart": "fail-closed-left", "x": 11.5, "y": -8.5 },
    { "forPart": "fail-last",        "x": 36.5, "y": -8.5 },
    { "forPart": "fail-last-left",   "x": 11.5, "y": -8.5 }
  ],
  "addons": [
    {
      "id": "fail-open",
      "file": "part-fail-open.svg",
      "label": "Fail Open (FO)",
      "group": "fail-indicator",
      "exclusive": true
    },
    {
      "id": "fail-open-left",
      "file": "part-fail-open.svg",
      "label": "Fail Open (FO) \u2014 Left",
      "group": "fail-indicator",
      "exclusive": true
    },
    {
      "id": "fail-closed",
      "file": "part-fail-closed.svg",
      "label": "Fail Closed (FC)",
      "group": "fail-indicator",
      "exclusive": true
    },
    {
      "id": "fail-closed-left",
      "file": "part-fail-closed.svg",
      "label": "Fail Closed (FC) \u2014 Left",
      "group": "fail-indicator",
      "exclusive": true
    },
    {
      "id": "fail-last",
      "file": "part-fail-last.svg",
      "label": "Fail Last (FL)",
      "group": "fail-indicator",
      "exclusive": true
    },
    {
      "id": "fail-last-left",
      "file": "part-fail-last.svg",
      "label": "Fail Last (FL) \u2014 Left",
      "group": "fail-indicator",
      "exclusive": true
    }
  ],
  "anchorSlots": {
    "PointNameLabel": [
      "top",
      "right",
      "bottom",
      "left"
    ],
    "AlarmIndicator": [
      "top-right",
      "top-left",
      "bottom-right",
      "bottom-left"
    ],
    "TextReadout": [
      "top",
      "right",
      "bottom",
      "left"
    ],
    "AnalogBar": [
      "right",
      "left"
    ],
    "FillGauge": [
      "right",
      "left"
    ],
    "Sparkline": [
      "right-top",
      "right-bottom",
      "left-top",
      "left-bottom"
    ],
    "DigitalStatus": [
      "top",
      "right",
      "bottom",
      "left"
    ]
  },
  "defaultSlots": {
    "AlarmIndicator": "top-right",
    "TextReadout": "bottom",
    "DigitalStatus": "bottom",
    "Sparkline": "right-top",
    "PointNameLabel": "top"
  },
  "bindableParts": [
    {
      "partId": "body",
      "label": "Valve Body",
      "category": "equipment"
    },
    {
      "partId": "actuator",
      "label": "Actuator",
      "category": "actuator"
    }
  ]
}
