    "TextReadout": [
      "top",
      "right",
      "bottom",
      "left"
    ],
    "AnalogBar": [
      "right",
      "left"
    ],
    "FillGauge": [
      "right",
      "left"
    ],
    "Sparkline": [
      "right-top",
      "right-bottom",
      "left-top",
      "left-bottom"
    ],
    "DigitalStatus": [
      "top",
      "right",
      "bottom",
      "left"
    ]
