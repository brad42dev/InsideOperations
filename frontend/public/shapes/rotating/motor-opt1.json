{
  "$schema": "io-shape-v1",
  "shape_id": "motor",
  "version": "1.0",
  "display_name": "Motor",
  "category": "rotating",
  "subcategory": "motor",
  "tags": ["motor", "electric", "rotating", "drive"],
  "recognition_class": "motor",
  "variants": {
    "options": {
      "opt1": { "file": "motor-opt1.svg", "label": "Circle (Vertical Shaft)" },
      "opt2": {
        "file": "motor-opt2.svg",
        "label": "Rectangle (Horizontal Shaft)"
      }
    },
    "configurations": []
  },
  "alarmBinding": {
    "stateSource": "point_alarm_state",
    "priorityMapping": {
      "1": "alarm_critical",
      "2": "alarm_high",
      "3": "alarm_medium",
      "4": "alarm_advisory"
    },
    "unacknowledgedFlash": true,
    "flashRate": "1Hz"
  },
  "geometry": { "viewBox": "0 0 40 40", "width": 40, "height": 40 },
  "connections": [
    {
      "id": "shaft",
      "type": "mechanical",
      "x": 20,
      "y": 4,
      "direction": "top"
    },
    {
      "id": "electrical",
      "type": "electrical",
      "x": 4,
      "y": 20,
      "direction": "left"
    }
  ],
  "textZones": [
    {
      "id": "tagname",
      "x": 20,
      "y": -6,
      "width": 40,
      "anchor": "middle",
      "fontSize": 11
    }
  ],
  "valueAnchors": [
    { "nx": 0.5, "ny": 1.2, "preferredElement": "text_readout" }
  ],
  "alarmAnchor": { "nx": 1.1, "ny": -0.15 },
  "states": {
    "running": "io-running",
    "stopped": "io-stopped",
    "fault": "io-fault",
    "transitioning": "io-transitioning",
    "oos": "io-oos"
  }
}
