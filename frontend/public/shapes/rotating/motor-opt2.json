{
  "$schema": "io-shape-v1",
  "shape_id": "motor",
  "version": "1.0",
  "display_name": "Motor",
  "category": "rotating",
  "subcategory": "motor",
  "tags": ["motor", "electric", "rotating", "drive"],
  "recognition_class": "motor",
  "variants": {
    "options": {
      "opt1": { "file": "motor-opt1.svg", "label": "Circle (Vertical Shaft)" },
      "opt2": {
        "file": "motor-opt2.svg",
        "label": "Rectangle (Horizontal Shaft)"
      }
    },
    "configurations": []
  },
  "alarmBinding": {
    "stateSource": "point_alarm_state",
    "priorityMapping": {
      "1": "alarm_critical",
      "2": "alarm_high",
      "3": "alarm_medium",
      "4": "alarm_advisory"
    },
    "unacknowledgedFlash": true,
    "flashRate": "1Hz"
  },
  "geometry": { "viewBox": "0 0 50 30", "width": 50, "height": 30 },
  "connections": [
    {
      "id": "shaft-left",
      "type": "mechanical",
      "x": 13,
      "y": 15,
      "direction": "left"
    },
    {
      "id": "shaft-right",
      "type": "mechanical",
      "x": 37,
      "y": 15,
      "direction": "right"
    }
  ],
  "textZones": [
    {
      "id": "tagname",
      "x": 25,
      "y": -6,
      "width": 50,
      "anchor": "middle",
      "fontSize": 11
    }
  ],
  "valueAnchors": [
    { "nx": 0.5, "ny": 1.3, "preferredElement": "text_readout" }
  ],
  "alarmAnchor": { "nx": 1.15, "ny": -0.2 },
  "states": {
    "running": "io-running",
    "stopped": "io-stopped",
    "fault": "io-fault",
    "transitioning": "io-transitioning",
    "oos": "io-oos"
  }
}
