{
  "$schema": "io-shape-v1",
  "shape_id": "mixer",
  "version": "1.0",
  "display_name": "Mixer — Agitator",
  "category": "mixers",
  "subcategory": "agitator",
  "tags": ["mixer", "agitator", "stirrer"],
  "recognition_class": "mixer",
  "variants": {
    "options": {
      "opt1": { "file": "mixer.svg", "label": "ISA Standard" }
    },
    "configurations": []
  },
  "alarmBinding": {
    "stateSource": "point_alarm_state",
    "priorityMapping": {
      "1": "alarm_critical",
      "2": "alarm_high",
      "3": "alarm_medium",
      "4": "alarm_advisory"
    },
    "unacknowledgedFlash": true,
    "flashRate": "1Hz"
  },
  "geometry": { "viewBox": "0 0 60 30", "width": 60, "height": 30 },
  "connections": [
    { "id": "shaft", "type": "mechanical", "x": 30, "y": 2, "direction": "top" }
  ],
  "textZones": [
    {
      "id": "tagname",
      "x": 30,
      "y": -6,
      "width": 60,
      "anchor": "middle",
      "fontSize": 11
    }
  ],
  "valueAnchors": [
    { "nx": 0.5, "ny": 1.3, "preferredElement": "text_readout" }
  ],
  "alarmAnchor": { "nx": 1.1, "ny": -0.2 },
  "states": {
    "running": "io-running",
    "stopped": "io-stopped",
    "fault": "io-fault",
    "transitioning": "io-transitioning",
    "oos": "io-oos"
  }
}
