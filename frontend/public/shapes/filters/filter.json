  },
  "geometry": { "viewBox": "0 0 50 60", "width": 50, "height": 60 },
  "connections": [
    { "id": "inlet",  "type": "process", "x": 6,  "y": 10, "direction": "left" },
    { "id": "outlet", "type": "process", "x": 44, "y": 10, "direction": "right" },
    { "id": "drain",  "type": "process", "x": 25, "y": 50, "direction": "bottom" }
