{
  "$schema": "io-shape-v1",
  "shape_id": "filter",
  "version": "1.0",
  "display_name": "Filter (Standard)",
  "category": "filters",
  "subcategory": "standard",
  "tags": ["filter", "strainer", "separation"],
  "recognition_class": "filter",
  "variants": {
    "options": {
      "opt1": { "file": "filter.svg", "label": "ISA Standard" }
    },
    "configurations": []
  },
  "alarmBinding": {
