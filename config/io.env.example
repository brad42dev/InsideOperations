# =============================================================================
# Inside/Operations — Production Environment Configuration
# =============================================================================
#
# Copy this file to /opt/io/config/io.env on the server and fill in every
# value.  This file is loaded by all IO systemd services via EnvironmentFile=.
#
# SECURITY: Restrict file permissions after editing:
#   sudo chmod 600 /opt/io/config/io.env
#   sudo chown root:root /opt/io/config/io.env
#
# The deploy.sh script will not start services until this file exists.
# =============================================================================

# =============================================================================
# 1. Database (required by all services)
# =============================================================================

# PostgreSQL connection URL — update user/password/host/dbname as needed.
IO_DATABASE_URL=postgresql://io:CHANGE_THIS_PASSWORD@localhost:5432/io_production

# Max DB connections per service pool (11 services × this value must be ≤ postgres max_connections).
# Default postgres max_connections = 100; set to 8 here for 11 services = 88 total.
IO_DB_MAX_CONNECTIONS=8

# =============================================================================
# 2. Security secrets (CHANGE ALL OF THESE — use a password manager)
# =============================================================================

# JWT signing secret — minimum 32 random characters.
# Generate: openssl rand -hex 32
IO_JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# Shared secret for inter-service calls (API Gateway ↔ downstream services).
# Generate: openssl rand -hex 32
IO_SERVICE_SECRET=CHANGE_THIS_TO_A_DIFFERENT_RANDOM_SECRET

# MFA enforcement
AUTH_MFA_GRACE_PERIOD_HOURS=72
AUTH_MFA_MAX_FAILURES=5
AUTH_MFA_LOCKOUT_DURATION_SEC=1800

# =============================================================================
# 3. Service ports (defaults shown — change only if ports conflict)
# =============================================================================

PORT=3000               # api-gateway  (overridden per service unit)

# =============================================================================
# 4. Service URLs (used by API Gateway to proxy to downstream services)
# =============================================================================

AUTH_SERVICE_URL=http://127.0.0.1:3009
DATA_BROKER_URL=http://127.0.0.1:3001
EVENT_SERVICE_URL=http://127.0.0.1:3003
IMPORT_SERVICE_URL=http://127.0.0.1:3006
ALERT_SERVICE_URL=http://127.0.0.1:3007
PARSER_SERVICE_URL=http://127.0.0.1:3004
RECOGNITION_SERVICE_URL=http://127.0.0.1:3010

# =============================================================================
# 5. CORS (restrict to your actual hostname/IP in production)
# =============================================================================

# Comma-separated list of allowed CORS origins.
# Example: https://io.example.com,https://192.168.1.100
CORS_ALLOWED_ORIGINS=https://CHANGE_THIS_TO_YOUR_SERVER_IP_OR_DOMAIN

# Public-facing URL of this installation (used in SAML ACS and mobile links).
FRONTEND_URL=https://CHANGE_THIS_TO_YOUR_SERVER_IP_OR_DOMAIN

# =============================================================================
# Alert Service External Heartbeat (optional — set URL to enable)
# =============================================================================
ALERT_HEARTBEAT_URL=
ALERT_HEARTBEAT_INTERVAL_SEC=60

# =============================================================================
# 6. Email (required for alert notifications and EULA emails)
# =============================================================================

SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@io.internal
SMTP_TLS=true

# =============================================================================
# 7. File storage
# =============================================================================

# Directory for rendered SVG tile pyramids (must be writable by io services).
TILE_STORAGE_DIR=/opt/io/tiles
TILE_MAX_ZOOM=5
TILE_SIZE=256

# Directory for export files (CSV, PDF, etc.).
IO_EXPORT_DIR=/opt/io/exports

# Tile cache and export file retention.
TILE_RETENTION_HOURS=168
EXPORT_RETENTION_HOURS=24

# Export job worker concurrency and per-user limits.
EXPORT_MAX_WORKERS=3
EXPORT_PER_USER_LIMIT=5
EXPORT_MAX_FILE_SIZE_MB=500

# Bulk update upload constraints.
BULK_UPDATE_MAX_UPLOAD_MB=50
BULK_UPDATE_MAX_ROWS=50000

# Backup storage location and retention policy.
BACKUP_STORAGE_DIR=/opt/io/backups
BACKUP_RETENTION_COUNT=7
BACKUP_SCHEDULE=0 2 * * *

# =============================================================================
# 8. OPC UA
# =============================================================================

# Default OPC UA endpoint (can also be configured per-server in Settings UI).
OPC_DEFAULT_ENDPOINT=opc.tcp://localhost:4840

# =============================================================================
# OPC Service Data Buffering
# =============================================================================
OPC_BUFFER_MEMORY_SECONDS=60
OPC_BUFFER_DISK_PATH=/var/lib/io-opc/buffer/
OPC_BUFFER_DISK_MAX_MB=1024

# =============================================================================
# 9. TimescaleDB retention (defaults shown)
# =============================================================================

RETENTION_1M_DAYS=90
RETENTION_5M_DAYS=365
RETENTION_1H_DAYS=1825

# =============================================================================
# 10. Observability
# =============================================================================

IO_LOG_LEVEL=info
IO_TRACING_ENABLED=false
IO_METRICS_COLLECTOR_ENABLED=true

# =============================================================================
# 11. Mobile / PWA
# =============================================================================

MOBILE_SYNC_INTERVAL_MS=30000
MOBILE_HEARTBEAT_INTERVAL_MS=60000
MOBILE_OFFLINE_CACHE_DURATION_MINS=480
MOBILE_GPS_REQUIRED=false
MOBILE_MIN_TOUCH_TARGET_PX=44

# =============================================================================
# TLS Certificate Management
# =============================================================================
IO_CERT_DIR=/etc/io/certs
IO_ACME_WEBROOT=/var/www/acme-challenge
IO_CERT_RENEW_DAYS=30
